generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum MaintenanceStatus {
  NEW
  ACCEPTED
  COMPLETED
  CANCELLED
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  CONVERTED
  EXPIRED
}

enum UserRole {
  PLAYER
  VENDOR
  TECHNICIAN
  ADMIN
}

model User {
  id             String            @id @default(cuid())
  name           String
  phone          String?           @unique
  email          String?           @unique
  role           UserRole          @default(PLAYER)
  isActive       Boolean           @default(true)
  vendorCourts   Court[]           @relation("VendorCourts")
  vendorJobs     MaintenanceJob[]  @relation("VendorJobs")
  technicianJobs MaintenanceJob[]  @relation("TechnicianJobs")
  bookings       Booking[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model Court {
  id          String    @id @default(cuid())
  name        String
  area        String
  areaLabel   String
  sport       String
  sportLabel  String
  price       String
  priceLabel  String
  badge       String
  description String
  isActive    Boolean   @default(true)
  vendorId    String?
  vendor      User?     @relation("VendorCourts", fields: [vendorId], references: [id])
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Booking {
  id           String        @id @default(cuid())
  courtId      String
  userId       String?
  customerName String
  email        String?
  phone        String
  startsAt     DateTime
  endsAt       DateTime
  status       BookingStatus @default(PENDING)
  notes        String?
  amountCents  Int           @default(0)
  seriesId     String?
  repeatPattern String?      
  repeatCount  Int           @default(1)
  occurrenceIndex Int        @default(0)
  court        Court         @relation(fields: [courtId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([courtId, startsAt, endsAt])
  @@index([seriesId])
}

model MaintenanceJob {
  id            String            @id @default(cuid())
  title         String
  category      String
  vendorName    String
  customerName  String
  phone         String
  status        MaintenanceStatus @default(NEW)
  notes         String?
  vendorId      String?
  technicianId  String?
  vendor        User?             @relation("VendorJobs", fields: [vendorId], references: [id])
  technician    User?             @relation("TechnicianJobs", fields: [technicianId], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model WaitlistEntry {
  id               String         @id @default(cuid())
  courtId          String
  userId           String?
  customerName     String
  email            String?
  phone            String
  startsAt         DateTime
  endsAt           DateTime
  status           WaitlistStatus @default(WAITING)
  notes            String?
  repeatPattern    String?
  repeatCount      Int            @default(1)
  seriesId         String?
  convertedBookingId String?
  notifiedAt       DateTime?
  court            Court          @relation(fields: [courtId], references: [id])
  user             User?          @relation(fields: [userId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([courtId, status, startsAt])
  @@index([seriesId])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  actorName   String?
  actorRole   UserRole?
  action      String
  entityType  String
  entityId    String?
  message     String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([action])
}
